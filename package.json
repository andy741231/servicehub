{
  "name": "service-hub",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "start": "node server/src/index.js",
    "postinstall": "npx prisma generate",
    "seed:users": "node prisma/seed-users.js",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prisma": "^5.22.0",
    "turbo": "latest"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  }
}
