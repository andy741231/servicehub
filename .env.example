# Copy this file to .env and fill in values for local development.
# Ask a team member for the actual credentials.
#
# Database: Azure SQL (free-test-servicehub)
# No local database or Docker needed — connects directly to Azure SQL.
DATABASE_URL="sqlserver://houstonservice-test.database.windows.net:1433;database=free-test-servicehub;user=servicehub_dev;password=<ask_team>;encrypt=true;trustServerCertificate=false;connectionTimeout=30"

# JWT secrets — use long random strings in production
JWT_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_a_different_long_random_string

# Frontend dev server URL (for CORS in local dev)
CLIENT_URL=http://localhost:3000

# Email (App 3 — optional for now)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Azure Storage (future)
AZURE_STORAGE_CONNECTION_STRING=
