# Production environment - set these as Azure App Service Application Settings
# Connects to: free-production-servicehub (Azure SQL)
DATABASE_URL="sqlserver://houstonservice-test.database.windows.net:1433;database=free-production-servicehub;user=<db_user>;password=<db_password>;encrypt=true;trustServerCertificate=false;connectionTimeout=30"

NODE_ENV=production
JWT_SECRET=<strong_random_secret>
JWT_REFRESH_SECRET=<strong_random_secret>
PORT=4000
CLIENT_URL=https://<your-app>.azurewebsites.net

# Email (App 3)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Azure Storage
AZURE_STORAGE_CONNECTION_STRING=
